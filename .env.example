# Bring your own OpenAI API key (BYOK). Generate one at https://platform.openai.com/api-keys
# This file MUST contain placeholders only — never a real key. Real keys belong in `.env` (gitignored).
OPENAI_API_KEY=sk-proj-REPLACE_ME_WITH_YOUR_OWN_OPENAI_KEY

# Advisor language provider:
# - auto: Wemik Brain first, Ollama if available, OpenAI only when enabled
# - local: deterministic Wemik Brain only
# - ollama: local Ollama wording polish
# - openai: OpenAI wording polish for stronger prompt interpretation
WEMIK_ADVISOR_PROVIDER=openai
WEMIK_ADVISOR_MODEL=gpt-5.3-codex
WEMIK_ADVISOR_AI=true

# Optional free local model path.
WEMIK_OLLAMA_MODEL=llama3.1:8b

# AI Review Patch provider.
WEMIK_TIER2_MODEL=gpt-5.3-codex
